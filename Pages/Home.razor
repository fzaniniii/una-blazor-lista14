@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4 shadow-sm">
                <img src="https://lh3.googleusercontent.com/d/1hmjgD7_y4cmkJYT3abenYr6MKBG6DQJp" 
                     class="rounded-circle mb-3"
                     width="120"
                     style="object-fit: cover; aspect-ratio: 1/1;" />
                <h3 class="fw-bold">Fábio Zanini</h3>
                <p class="text-muted" style="font-size: 0.9rem;">
                    Desenvolvedor de Software em Formação (ADS) | Transição de Carreira: Administração para Tech | JavaScript | SQL | Ex-Analista de Risco
                </p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4 border-bottom pb-2">Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                @* O segredo está dentro deste componente abaixo *@
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
